# =================================================================
# Core System Configuration
# =================================================================

# ART_BANNER_NAME: The text string displayed in ASCII art when booting up.
ART_BANNER_NAME: "OPENDOOR"

# ART_BANNER_FONT: The pyfiglet font type utilized for the boot banner.
ART_BANNER_FONT: "ansi_shadow"

# LATITUDE & LONGITUDE: Geographic coordinates for hyper-local tools like weather reporting.
LATITUDE: 0.0
LONGITUDE: 0.0

# DEFAULT_MODEL: The default fallback model for agents.
DEFAULT_MODEL: "gpt-5.4-nano"

# SUBAGENT_MODEL: The model used for subagents when delegated.
SUBAGENT_MODEL: "gpt-5.4-mini"

